# =============================================================================
#  YOUR CONFIG FILE (.env) — WHAT TO DO
# =============================================================================
#
#  This file lists every API key and setting the app understands.
#  There are no “boxes” in this file: each setting is ONE line that looks like:
#
#       NAME=value
#
#  Put your secret immediately after the “=” with NO space before or after it.
#  Example (fake key):   GROQ_API_KEY=gsk_abc123
#
#  HOW TO CREATE YOUR REAL FILE:
#    1) Copy this file and rename the copy to:  .env
#       (On Mac, in Terminal:)
#           cd outreach-automation
#           cp .env.example .env
#
#    2) Open .env in any editor:
#       • Mac: open -e .env     OR     nano .env
#       • Windows: Notepad
#
#    3) Scroll through and type your keys on the lines below where you see NAME=
#
#    4) Save and restart the app (close Terminal / stop the server, start again).
#
#  Lines starting with # are comments (ignored).
#
# =============================================================================


# -----------------------------------------------------------------------------
#  REQUIRED — Groq (AI). Without this, nothing runs.
#  Sign up: https://console.groq.com  →  API keys  →  Create key
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
#  OPTIONAL — Gemini (Google AI Studio). Used if GROQ_API_KEY is missing or as a fallback.
#  Get key: https://ai.google.dev  →  API key
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash


# -----------------------------------------------------------------------------
#  WHERE TO SAVE RESULTS (pick ONE approach in the app, unless you use Dry run)
#
#  Outlook: set OUTLOOK_CLIENT_ID below.
#  Google:  leave Outlook blank, add credentials.json (see GETTING_STARTED.md),
#           and choose “Google” in the app OR set OUTREACH_EXPORT=google
# -----------------------------------------------------------------------------

# Azure → App registrations → Application (client) ID  (see GETTING_STARTED.md)
OUTLOOK_CLIENT_ID=

# Usually leave this commented unless your IT team gave you a tenant ID:
# OUTLOOK_TENANT_ID=common

# Force export mode when using command line:  outlook  |  google
# OUTREACH_EXPORT=outlook


# -----------------------------------------------------------------------------
#  EMAIL DISCOVERY — all optional. Order (after on-page HTML):
#  Contact/about scrape (D) → Hunter → Snov → Apollo → Anymail company →
#  Anymail person → Findymail → Skrapp → pattern guess + verifier (B).
#  Confirm each vendor’s current free tier / credits on their site.
# -----------------------------------------------------------------------------

# https://hunter.io
HUNTER_API_KEY=

# https://snov.io — BOTH lines required
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# https://apollo.io — API credits on free tier (verify current limits)
APOLLO_API_KEY=

# https://anymailfinder.com — one key used for company + person endpoints
ANYMAIL_FINDER_API_KEY=

# https://findymail.com — trial/small free allotments vary by plan
FINDYMAIL_API_KEY=

# https://skrapp.io — API access may require paid plan; optional if you have a key
SKRAPP_API_KEY=

# Pattern guessing (B): needs at least one verifier to avoid unverified guesses
# https://www.zerobounce.net (free monthly validate quota)
ZEROBOUNCE_API_KEY=

# https://www.abstractapi.com/api/email-validation (free monthly requests)
ABSTRACT_EMAIL_VALIDATION_API_KEY=

# Set to 0 to skip extra fetches of /contact, /about, … on each company site
# OUTREACH_SCRAPE_CONTACT_PAGES=1

# Parse mailto / JSON-LD on the list URL’s HTML before Groq (single fetch)
# OUTREACH_LIST_PAGE_EMAILS=1

# Set to 0 to skip first+last pattern guesses after APIs
# OUTREACH_PATTERN_GUESS=1


# -----------------------------------------------------------------------------
#  FINE-TUNING (safe to ignore at first)
# -----------------------------------------------------------------------------

GROQ_MODEL=llama-3.3-70b-versatile

# Smaller numbers if Groq says “too large” or rate limits:
# GROQ_MAX_PAGE_CHARS=8000
# GROQ_EXTRACT_MAX_TOKENS=3072
# GROQ_ROW_DELAY_SEC=1.0
