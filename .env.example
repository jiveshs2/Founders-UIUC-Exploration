# Groq (https://console.groq.com) — paste your key after the = (no quotes)
GROQ_API_KEY=

# Email finder chain (any combination; order: Hunter → Snov → Apollo).
# If one hits quota or finds nothing, the next is tried.

# Hunter.io — https://hunter.io
HUNTER_API_KEY=

# Snov.io — https://snov.io/api (Account → API → Client ID & Secret)
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# Apollo.io — https://docs.apollo.io/ (master API key; bulk_match uses credits)
APOLLO_API_KEY=

# Optional: model id (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
